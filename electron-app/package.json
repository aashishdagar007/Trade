{
  "name": "tradepro-terminal",
  "version": "0.1.0",
  "description": "Bloomberg-style terminal — Electron shell",
  "private": true,
  "main": "main/main.js",
  "scripts": {
    "electron:dev":   "concurrently \"npm run renderer:dev\" \"wait-on http://localhost:5174 && electron .\"",
    "electron:build": "npm run renderer:build && electron-builder",
    "renderer:dev":   "vite renderer --port 5174",
    "renderer:build": "vite build renderer"
  },
  "dependencies": {
    "electron-log":        "^5.1.2",
    "framer-motion":       "^12.38.0",
    "lightweight-charts":  "^5.1.0",
    "lucide-react":        "^1.8.0",
    "react":               "^19.2.4",
    "react-dom":           "^19.2.4",
    "react-grid-layout":   "^1.4.4"
  },
  "devDependencies": {
    "@types/react":             "^19.2.14",
    "@types/react-dom":         "^19.2.3",
    "@types/react-grid-layout": "^1.3.5",
    "@vitejs/plugin-react":     "^6.0.1",
    "concurrently":             "^8.2.2",
    "electron":                 "^34.0.0",
    "electron-builder":         "^24.13.3",
    "typescript":               "^5.6.3",
    "vite":                     "^8.0.4",
    "wait-on":                  "^7.2.0"
  },
  "build": {
    "appId":         "com.tradepro.terminal",
    "productName":   "TradePro Terminal",
    "directories":   { "output": "dist-electron" },
    "files":         ["main/**", "renderer/dist/**"],
    "win": {
      "target": "nsis",
      "icon":   "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon":   "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon":   "assets/icon.png"
    }
  }
}
